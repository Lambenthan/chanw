---
/**
 * /garden — Maggie 同款 Garden subpage：5 类 content collection 的统一时间流。
 *
 * Maggie 原项目的 /garden 是把 essays / notes / patterns / talks / smidgeons
 * 合并按时间倒序展示——"一座持续生长的花园"的字面落地。
 *
 * 本站当前这 5 个 collection 均为空（用户即将填长文 / 笔记 / 设计模式 / 演讲）。
 * 所以这个页面现在会显示空 stream，等内容填进去会自动长出来。
 *
 * book chapters 不在这里——它们属 /library/[book]/[chapter] 路由，由 /library 索引。
 */
import Layout from "../layouts/Layout.astro";
import PageWrapper from "../components/layouts/PageWrapper.astro";
import Title2 from "../components/mdx/typography/Title2.astro";
import TitleWithCount from "../components/layouts/TitleWithCount.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";
import { extractBaseSlug } from "../utils/versionUtils";

type Entry = {
	type: "essay" | "note" | "pattern" | "talk" | "smidgeon";
	title: string;
	description?: string;
	updated?: Date;
	href: string;
};

const essays = await getCollection("essays", ({ data }) => !data.draft);
const notes = await getCollection("notes", ({ data }) => !data.draft);
const patterns = await getCollection("patterns", ({ data }) => !data.draft);
const talks = await getCollection("talks", ({ data }) => !data.draft);
const smidgeons = await getCollection("smidgeons", ({ data }) => !data.draft);

const items: Entry[] = [
	...essays.map((e) => ({
		type: "essay" as const,
		title: e.data.title,
		description: e.data.description,
		updated: e.data.updated,
		href: `/${extractBaseSlug(e.id)}`,
	})),
	...notes.map((n) => ({
		type: "note" as const,
		title: n.data.title,
		description: n.data.description,
		updated: n.data.updated,
		href: `/${extractBaseSlug(n.id)}`,
	})),
	...patterns.map((p) => ({
		type: "pattern" as const,
		title: p.data.title,
		description: p.data.description,
		updated: p.data.updated,
		href: `/${extractBaseSlug(p.id)}`,
	})),
	...talks.map((t) => ({
		type: "talk" as const,
		title: t.data.title,
		description: t.data.description,
		updated: t.data.updated,
		href: `/${extractBaseSlug(t.id)}`,
	})),
	...smidgeons.map((s) => ({
		type: "smidgeon" as const,
		title: s.data.title ?? "(smidgeon)",
		description: s.data.description,
		updated: s.data.updated,
		href: `/${extractBaseSlug(s.id)}`,
	})),
].sort((a, b) => {
	const ad = a.updated ?? new Date(0);
	const bd = b.updated ?? new Date(0);
	return new Date(bd).getTime() - new Date(ad).getTime();
});

const TYPE_LABEL: Record<Entry["type"], string> = {
	essay: "Essay",
	note: "Note",
	pattern: "Pattern",
	talk: "Talk",
	smidgeon: "Smidgeon",
};

const fmtDate = (d?: Date) =>
	d
		? new Date(d).toLocaleDateString("en-CA", {
				year: "numeric",
				month: "short",
				day: "numeric",
			})
		: "";
---

<Layout
	title="The Garden — Chanw"
	desc="一座持续生长的学术花园 —— 长文、笔记、研究随想慢慢长出来。"
>
	<PageWrapper>
		<header style="margin-bottom: var(--space-xl);">
			<TitleWithCount posts={items}>
				<div class="back-link" slot="header-right">
					<a href="/">
						<Icon name="heroicons:arrow-left" size={16} />
						<span> Back to Home </span>
					</a>
				</div>
				The Garden
			</TitleWithCount>
			<Title2>
				一座持续生长的学术花园 —— 长文、笔记、研究随想慢慢长出来。
			</Title2>
		</header>

		{
			items.length === 0 ? (
				<div class="empty-state">
					<p>花园刚清出场地，还没栽东西。长文 / 笔记 / 设计模式 / 演讲将陆续填入。</p>
					<p>书稿章节在 <a href="/library">/library</a>。</p>
				</div>
			) : (
				<section class="stream">
					{items.map((it) => (
						<a class="entry" href={it.href}>
							<div class="entry-meta">
								<time>{fmtDate(it.updated)}</time>
								<span class="entry-type">{TYPE_LABEL[it.type]}</span>
							</div>
							<h3 class="entry-title">{it.title}</h3>
							{it.description && <p class="entry-desc">{it.description}</p>}
						</a>
					))}
				</section>
			)
		}
	</PageWrapper>
</Layout>

<style>
	.back-link {
		display: inline-flex;
		align-items: center;
		height: 100%;
		position: relative;
		left: -2rem;
	}

	@media (max-width: 1440px) {
		.back-link {
			left: 0;
		}
	}

	.back-link a {
		display: inline-flex;
		align-items: center;
		gap: var(--space-3xs);
		color: var(--color-gray-600);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		transition: color 0.2s ease;
	}

	.back-link a:hover {
		color: var(--color-bright-crimson);
	}

	.empty-state {
		padding: var(--space-xl) 0;
		color: var(--color-gray-600);
		font-family: var(--font-body);
		font-size: var(--font-size-base);
		line-height: 1.7;
	}

	.empty-state p {
		margin: 0 0 var(--space-s);
	}

	.empty-state a {
		color: var(--color-sea-blue);
		text-decoration: none;
		border-bottom: 1px solid var(--color-tinted-cream);
		transition: border-color 0.2s ease;
	}

	.empty-state a:hover {
		border-bottom-color: var(--color-sea-blue);
	}

	.stream {
		display: flex;
		flex-direction: column;
	}

	.entry {
		display: block;
		padding: var(--space-s) 0;
		border-bottom: 1px solid var(--color-tinted-cream);
		text-decoration: none;
		color: inherit;
		transition: background-color 0.2s ease;
	}

	.entry:hover {
		background: color-mix(in srgb, var(--color-sea-blue) 4%, transparent);
	}

	.entry-meta {
		display: flex;
		align-items: baseline;
		gap: var(--space-xs);
		margin-bottom: var(--space-3xs);
		font-family: "TNR Numerals", "Times New Roman", serif;
		font-size: var(--font-size-sm);
		color: var(--color-gray-500);
	}

	.entry-meta time {
		font-variant-numeric: tabular-nums;
	}

	.entry-type {
		font-family: var(--font-sans);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		font-size: var(--font-size-xs);
	}

	.entry-title {
		font-family: var(--font-serif);
		font-size: calc(var(--font-size-base) * 1.15);
		font-weight: 500;
		margin: 0 0 var(--space-3xs);
		color: var(--color-gray-800);
		line-height: 1.3;
	}

	.entry:hover .entry-title {
		color: var(--color-sea-blue);
	}

	.entry-desc {
		font-size: var(--font-size-base);
		line-height: 1.6;
		color: var(--color-gray-700);
		margin: 0;
	}
</style>
