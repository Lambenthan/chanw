---
import Layout from "../layouts/Layout.astro";
import Title2 from "../components/mdx/typography/Title2.astro";
import NewsCard from "../components/cards/NewsCard.astro";
import TitleWithCount from "../components/layouts/TitleWithCount.astro";
import PageWrapper from "../components/layouts/PageWrapper.astro";
import { Icon } from "astro-icon/components";
import newsItems from "../data/news.json";

type NewsItem = {
	title: string;
	url: string;
	source: string;
	date?: string;
	group: string;
};

// Anthropic 系内部多个子站合并为单一来源；Google 的两个子站合并
const SOURCE_NORMALIZE: Record<string, string> = {
	"Anthropic Research": "Anthropic",
	"Anthropic News": "Anthropic",
	"Anthropic Engineering": "Anthropic",
	"claude.com": "Anthropic",
	"code.claude.com": "Anthropic",
	"research.google": "Google AI",
};

function normalizeSource(src: string): string {
	return SOURCE_NORMALIZE[src] ?? src;
}

const GROUPS: { id: string; title: string; subtitle: string }[] = [
	{
		id: "labs",
		title: "AI Labs",
		subtitle: "厂商一手发布 —— 按发布方分桶，默认显示每家最新 30 条。",
	},
	{
		id: "papers",
		title: "Papers",
		subtitle: "近期论文 —— arXiv、HuggingFace Papers、研究院刊。",
	},
	{
		id: "gh",
		title: "GitHub",
		subtitle: "上升项目 —— 近期活跃、stars 增长快的开源仓库。",
	},
];

const SOURCE_PREVIEW = 30;
const SOURCE_MIN_COUNT = 5; // 小于此数的来源合并到"其他"

function byDateDesc(a: NewsItem, b: NewsItem) {
	const ad = a.date ? new Date(a.date).getTime() : 0;
	const bd = b.date ? new Date(b.date).getTime() : 0;
	return bd - ad;
}

const allItems = (newsItems as NewsItem[]).slice();

type SourceBucket = { source: string; items: NewsItem[] };
type GroupBlock =
	| { mode: "flat"; id: string; title: string; subtitle: string; items: NewsItem[] }
	| {
			mode: "by-source";
			id: string;
			title: string;
			subtitle: string;
			total: number;
			sources: SourceBucket[];
	  };

const blocks: GroupBlock[] = GROUPS.map((g) => {
	const items = allItems.filter((x) => x.group === g.id).sort(byDateDesc);

	if (g.id !== "labs") {
		return { mode: "flat", ...g, items };
	}

	// 按 normalized source 分桶
	const map = new Map<string, NewsItem[]>();
	for (const item of items) {
		const src = normalizeSource(item.source);
		if (!map.has(src)) map.set(src, []);
		map.get(src)!.push(item);
	}

	// 拆出大桶与小桶
	const big: SourceBucket[] = [];
	const small: NewsItem[] = [];
	for (const [src, list] of map.entries()) {
		if (list.length >= SOURCE_MIN_COUNT) {
			big.push({ source: src, items: list });
		} else {
			small.push(...list);
		}
	}
	big.sort((a, b) => b.items.length - a.items.length);
	if (small.length > 0) {
		small.sort(byDateDesc);
		big.push({ source: "其他", items: small });
	}

	return {
		mode: "by-source",
		...g,
		total: items.length,
		sources: big,
	};
});

// 从 labs 块抽锚点导航
const labsBlock = blocks.find((b) => b.id === "labs" && b.mode === "by-source") as
	| Extract<GroupBlock, { mode: "by-source" }>
	| undefined;
const labsAnchors = labsBlock?.sources.map((s) => ({
	slug: `labs-${s.source.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`,
	source: s.source,
	count: s.items.length,
})) ?? [];

function sourceSlug(source: string): string {
	return `labs-${source.toLowerCase().replace(/[^a-z0-9]+/g, "-")}`;
}
---

<Layout title="News" desc="AI 行业全量动态索引：厂商一手发布、近期论文、热门开源项目">
	<PageWrapper>
		<header style="margin-bottom: var(--space-xl);">
			<TitleWithCount posts={allItems}>
				<div class="back-link" slot="header-right">
					<a href="/">
						<Icon name="heroicons:arrow-left" size={16} />
						<span> Back to Home </span>
					</a>
				</div>
				News
			</TitleWithCount>
			<Title2>AI 行业全量动态索引 —— 厂商一手发布按来源分桶、近期论文与上升仓库整体铺开。</Title2>
		</header>

		{
			labsAnchors.length > 0 && (
				<nav class="anchor-nav" aria-label="AI Labs 来源跳转">
					<span class="anchor-label">跳转：</span>
					{labsAnchors.map((a) => (
						<a href={`#${a.slug}`} class="anchor-link">
							{a.source}
							<span class="anchor-count">{a.count}</span>
						</a>
					))}
					<a href="#group-papers" class="anchor-link"><strong>Papers</strong></a>
					<a href="#group-gh" class="anchor-link"><strong>GitHub</strong></a>
				</nav>
			)
		}

		{
			blocks.map((block) => (
				<section class="news-group" id={`group-${block.id}`}>
					<header class="group-header">
						<span class="group-count">
							{block.mode === "by-source" ? block.total : block.items.length}
						</span>
						<h2 class="group-title">{block.title}</h2>
						<p class="group-subtitle">{block.subtitle}</p>
					</header>

					{block.mode === "by-source" ? (
						block.sources.map((src) => {
							const preview = src.items.slice(0, SOURCE_PREVIEW);
							const overflow = src.items.slice(SOURCE_PREVIEW);
							return (
								<div class="source-block" id={sourceSlug(src.source)}>
									<header class="source-header">
										<h3 class="source-name">{src.source}</h3>
										<span class="source-count">{src.items.length}</span>
									</header>
									<div class="news-grid">
										{preview.map((item) => (
											<NewsCard
												title={item.title}
												url={item.url}
												source={item.source}
												date={item.date}
											/>
										))}
									</div>
									{overflow.length > 0 && (
										<details class="source-overflow">
											<summary>
												<span>查看全部 {src.items.length} 条</span>
												<Icon name="heroicons:chevron-down" size={14} />
											</summary>
											<div class="news-grid news-grid-overflow">
												{overflow.map((item) => (
													<NewsCard
														title={item.title}
														url={item.url}
														source={item.source}
														date={item.date}
													/>
												))}
											</div>
										</details>
									)}
								</div>
							);
						})
					) : block.items.length > 0 ? (
						<div class="news-grid">
							{block.items.map((item) => (
								<NewsCard
									title={item.title}
									url={item.url}
									source={item.source}
									date={item.date}
								/>
							))}
						</div>
					) : (
						<p class="empty">本组暂无条目。</p>
					)}
				</section>
			))
		}
	</PageWrapper>
</Layout>

<style>
	.back-link {
		display: inline-flex;
		align-items: center;
		height: 100%;
		position: relative;
		left: -2rem;
	}

	@media (max-width: 1440px) {
		.back-link {
			display: inline-flex;
			top: 0;
			margin: 0;
			left: 1rem;
		}
	}

	.back-link a {
		display: inline-flex;
		align-items: center;
		position: relative;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: bold;
		transition: all 0.8s cubic-bezier(0.2, 1, 0.8, 1);
		margin: 0;
		padding: 0;
	}

	.back-link svg {
		width: 0;
		transition: all 0.8s cubic-bezier(0.2, 1, 0.8, 1);
		color: var(--color-gray-300);
		position: relative;
		top: 1px;
	}

	.back-link span {
		display: inline-block;
		transition: transform 0.3s cubic-bezier(0.2, 1, 0.8, 1);
		color: var(--color-gray-600);
	}

	.back-link a:hover svg {
		width: 16px;
		margin-right: 2px;
		color: var(--color-sea-blue);
	}

	.back-link a:hover span {
		transform: translate3d(3px, 0, 0);
		color: var(--color-sea-blue);
	}

	.anchor-nav {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-3xs) var(--space-xs);
		padding: var(--space-s) var(--space-m);
		margin-bottom: var(--space-xl);
		background: var(--color-light-cream);
		border: 1px solid var(--color-tinted-cream);
		border-radius: var(--border-radius-base);
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
	}

	.anchor-label {
		color: var(--color-gray-500);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-size: var(--font-size-xs);
		font-weight: bold;
	}

	.anchor-link {
		color: var(--color-gray-700);
		text-decoration: none;
		padding: var(--space-3xs) var(--space-2xs);
		border-radius: var(--border-radius-base);
		transition: all 0.3s ease-in-out;
		display: inline-flex;
		align-items: baseline;
		gap: 0.4em;
	}

	.anchor-link:hover {
		background: var(--color-cream);
		color: var(--color-crimson);
	}

	.anchor-count {
		font-variant-numeric: tabular-nums;
		color: var(--color-gray-500);
		font-size: var(--font-size-xs);
	}

	.news-group {
		margin-top: var(--space-xl);
	}

	.news-group + .news-group {
		margin-top: var(--space-2xl);
	}

	.group-header {
		display: grid;
		grid-template-columns: auto 1fr;
		grid-template-areas:
			"count title"
			".     subtitle";
		align-items: baseline;
		column-gap: var(--space-xs);
		row-gap: var(--space-3xs);
		margin-bottom: var(--space-m);
		padding-bottom: var(--space-xs);
		border-bottom: 1px solid var(--color-tinted-cream);
	}

	.group-count {
		grid-area: count;
		font-family: var(--font-serif);
		font-size: var(--font-size-md);
		font-weight: 400;
		color: var(--color-sea-blue);
		font-variant-numeric: tabular-nums;
		min-width: 1.5rem;
		text-align: right;
	}

	.group-title {
		grid-area: title;
		font-family: var(--font-serif);
		font-size: var(--font-size-xl);
		font-weight: normal;
		color: var(--color-gray-800);
		line-height: var(--leading-tight);
		margin: 0;
	}

	.group-subtitle {
		grid-area: subtitle;
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 300;
		color: var(--color-gray-600);
		line-height: var(--leading-snug);
		margin: 0;
	}

	.source-block {
		margin-top: var(--space-l);
		scroll-margin-top: var(--space-l);
	}

	.source-header {
		display: flex;
		align-items: baseline;
		gap: var(--space-xs);
		margin-bottom: var(--space-s);
	}

	.source-name {
		font-family: var(--font-serif);
		font-size: var(--font-size-lg);
		font-weight: normal;
		color: var(--color-gray-800);
		margin: 0;
	}

	.source-count {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-gray-500);
		font-variant-numeric: tabular-nums;
		text-transform: uppercase;
		letter-spacing: 0.05em;
	}

	.news-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: var(--space-xs);
	}

	@media (max-width: 1024px) {
		.news-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 640px) {
		.news-grid {
			grid-template-columns: 1fr;
		}
	}

	.source-overflow {
		margin-top: var(--space-s);
	}

	.source-overflow summary {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: bold;
		color: var(--color-sea-blue);
		padding: var(--space-2xs) var(--space-xs);
		cursor: pointer;
		display: inline-flex;
		align-items: center;
		gap: var(--space-3xs);
		border-radius: var(--border-radius-base);
		transition: all 0.3s ease-in-out;
		list-style: none;
		width: fit-content;
	}

	.source-overflow summary::-webkit-details-marker {
		display: none;
	}

	.source-overflow summary:hover {
		background: var(--color-light-cream);
		color: var(--color-crimson);
	}

	.source-overflow svg {
		transition: transform 0.3s ease-in-out;
	}

	.source-overflow[open] summary svg {
		transform: rotate(180deg);
	}

	.news-grid-overflow {
		margin-top: var(--space-s);
	}

	.empty {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-gray-500);
		font-style: italic;
		padding: var(--space-m) 0;
		text-align: center;
	}

	@media (max-width: 640px) {
		.group-header {
			grid-template-columns: auto 1fr;
		}

		.anchor-nav {
			padding: var(--space-xs);
		}
	}
</style>
