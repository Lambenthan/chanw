---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import Spacer from "../components/mdx/Spacer.astro";
import Title1 from "../components/mdx/typography/Title1.astro";
import SmallTitle2 from "../components/mdx/typography/SmallTitle2.astro";
import EssayCard from "../components/cards/EssayCard.astro";
import BookCard from "../components/cards/BookCard.astro";
import SkillCard from "../components/cards/SkillCard.astro";
import PageWrapper from "../components/layouts/PageWrapper.astro";
import { extractBaseSlug } from "../utils/versionUtils";
import newsItems from "../data/news.json";
import skillsData from "../data/skills.json";

const essays = await getCollection("essays", ({ data }) => data.featured === true && !data.draft);
const books = await getCollection("books");

const sortedEssays = essays
	.sort((a, b) => new Date(b.data.updated).getTime() - new Date(a.data.updated).getTime())
	.slice(0, 4);

// 首页 News 只展示最新 6 条（按发布时间倒序）；完整列表见 /news
const HOMEPAGE_NEWS_LIMIT = 6;
const homepageNews = (newsItems as { title: string; url: string; date?: string }[])
	.slice()
	.sort((a, b) => {
		const ad = a.date ? new Date(a.date).getTime() : 0;
		const bd = b.date ? new Date(b.date).getTime() : 0;
		return bd - ad;
	})
	.slice(0, HOMEPAGE_NEWS_LIMIT);

// Featured skills on homepage: pick a curated cross-section across categories.
// 首页 Skills 精选 5 个：跨 5 个不同子类覆盖完整科研流水线。
// 完整 130 项见 /skills。
const HOMEPAGE_SKILL_PICKS = new Set([
	"analyze-results",       // 科研 · 数据分析
	"academic-researcher",   // 科研 · 写作流程与纪律
	"manuscript-optimizer",  // 科研 · 语言润色
	"mermaid-diagram",       // 科研 · 图表绘制
	"pdf",                   // 通用文档代表
]);
// 注意 skills.json 里 pdf/docx/xlsx/pptx 等在多个分类下重复出现（/skills
// 页面分类展示需要），所以这里要按 slug 去重，确保首页只有 5 张卡
const featuredSkills: typeof skillsData = [];
const seenFeaturedSlugs = new Set<string>();
for (const s of skillsData) {
	if (HOMEPAGE_SKILL_PICKS.has(s.slug) && !seenFeaturedSlugs.has(s.slug)) {
		featuredSkills.push(s);
		seenFeaturedSlugs.add(s.slug);
	}
}
---

<Layout title="Chanw">
	<PageWrapper>
		<header class="page-header">
			<Title1 class="main-title reveal">
				<b>Chanw&rsquo;s Garden</b>
				makes essays on doing research and the latest in AI.
			</Title1>
			<div class="reveal">
				<SmallTitle2>
					Empiricist, tool curator, and mediocre developer.<br />
					Currently exploring AI for empirical research at
					<a href="https://github.com/Lambenthan" target="_blank" rel="noopener noreferrer">github.com/Lambenthan</a>.
				</SmallTitle2>
			</div>
		</header>

		<Spacer />

		<section class="reveal">
			<a href="/garden">
				<h2 class="garden-title">The Garden</h2>
			</a>
			<div class="subheader">
				一座持续生长的学术花园 —— 长文、笔记、研究随想慢慢长出来。
			</div>
		</section>

		<section class="garden-section">
			<section class="essays-section reveal">
				<a href="/garden" class="header-link">
					<h3 class="section-header">
						Essays
						<Icon name="heroicons:arrow-right" size={18} />
					</h3>
				</a>
				<div class="subheader">长文与书稿章节 —— 记录我对 AI 在各领域应用的所思所想。</div>
				<div class="essays-grid">
					{
						sortedEssays.map((essay) => (
							<EssayCard
								id={essay.id}
								slug={extractBaseSlug(essay.id)}
								cover={essay.data.cover}
								title={essay.data.title}
								growthStage={essay.data.growthStage}
								date={essay.data.updated}
								description={essay.data.description}
							/>
						))
					}
				</div>
			</section>

			<section class="reveal" style="grid-area: notes;">
				<a href="/news" class="header-link">
					<h3 class="section-header">
						News
						<Icon name="heroicons:arrow-right" size={18} />
					</h3>
				</a>
				<div class="subheader">
					AI 行业的最新动态 —— 模型发布、行业事件、热门开源项目，每日更新。
				</div>
				{
					homepageNews.map((item) => (
						<a href={item.url} target="_blank" rel="noopener noreferrer">
							<div class="index-note-card">
								<div class="icon">
									<Icon name="heroicons:bolt" size={20} />
								</div>
								<h3>{item.title}</h3>
							</div>
						</a>
					))
				}
			</section>

			<section class="patterns-section reveal">
				<a href="/skills" class="header-link">
					<h3 class="section-header">
						Skills
						<Icon name="heroicons:arrow-right" size={18} />
					</h3>
				</a>
				<div class="subheader">
					策展过的 Claude Code skills —— 科研流水线置顶（数据分析、文献综述、图表、写作）；通用文档处理、设计、开发扩展跟后。
				</div>
				<div class="patterns-grid">
					{
						featuredSkills.map((s) => (
							<SkillCard
								slug={s.slug}
								repo={s.repo}
								path={s.path}
								ref={s.ref}
								descriptionZh={s.descriptionZh}
							/>
						))
					}
				</div>
			</section>

			<section class="library-section reveal">
				<a href="/library" class="header-link">
					<h3 class="section-header">
						Library
						<Icon name="heroicons:arrow-right" size={18} />
					</h3>
				</a>
				<div class="subheader">我自己写的书。</div>
				<div class="books-grid">
					{
						books
							.slice(0, 8)
							.map((book) => (
								<BookCard
									small
									subtitle={book.data.subtitle}
									cover={book.data.cover}
									title={book.data.title}
									author={book.data.author}
									link={book.data.link}
								/>
							))
					}
				</div>
			</section>
		</section>
	</PageWrapper>
</Layout>

<style>
	.readmore-link {
		display: inline-flex;
		align-items: center;
		font-weight: 400;
		color: var(--color-crimson);
	}

	.readmore-link [data-icon] {
		transition: all 0.3s ease-in-out;
		position: relative;
		top: 2px;
		margin-left: var(--space-3xs);
	}

	.readmore-link:hover {
		color: var(--color-bright-crimson);
		cursor: pointer;
	}

	.readmore-link:hover [data-icon] {
		margin-left: var(--space-2xs);
		color: var(--color-sea-blue);
	}

	.index-note-card {
		display: flex;
		padding: var(--space-xs) 0 1.2rem;
		border-bottom: 1px solid var(--color-tinted-cream);
		transition: all 0.3s ease-in-out;
	}

	.index-note-card .icon {
		position: relative;
		top: 5px;
		flex-shrink: 0;
		color: var(--color-sea-blue);
	}

	.index-note-card h3 {
		color: var(--color-gray-800);
		transition: all 0.3s ease-in-out;
		font-family: var(--font-body);
		font-size: var(--font-size-base);
		font-weight: 400;
		line-height: var(--leading-snug);
		margin-left: var(--space-xs);
		transition: all 0.3s ease-in-out;
	}

	.index-note-card:hover {
		border-bottom: 1px solid var(--color-sea-blue);
		transform: scale3d(1.02, 1.02, 1.02);
	}

	.index-note-card:hover h3 {
		color: var(--color-crimson);
	}

	.garden-title {
		font-size: var(--font-size-2xl);
		font-family: var(--font-serif);
		color: var(--color-gray-800);
		font-weight: 100;
		line-height: var(--leading-snug);
		margin: var(--space-xs) 0 var(--space-2xs);
		transition: all 0.3s ease-in-out;
	}

	.garden-section {
		margin: var(--space-xl) 0 var(--space-s);
		display: grid;
		grid-gap: var(--space-xl);
		grid-template-columns: 1fr 1fr 1fr;
		grid-template-rows: auto;
		grid-template-areas:
			"essays essays notes"
			"patterns library library";
	}

	@media (max-width: 768px) {
		.garden-section {
			grid-gap: var(--space-s);
		}
	}

	@media (max-width: 640px) {
		.garden-section {
			grid-template-columns: 1fr;
			grid-gap: var(--space-l);
			grid-template-rows: auto;
			grid-template-areas: "essays" "notes" "patterns" "library";
		}
	}

	.section-header {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: 600;
		color: var(--color-gray-800);
		display: flex;
		align-items: center;
		margin-bottom: var(--space-3xs);
	}

	.section-header [data-icon] {
		transition: all 0.3s ease-in-out;
		position: relative;
		top: 2px;
		margin-left: var(--space-3xs);
	}

	.header-link:hover .section-header {
		color: var(--color-bright-crimson);
	}

	.header-link:hover .section-header [data-icon] {
		margin-left: var(--space-2xs);
		color: var(--color-sea-blue);
	}

	.subheader {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: 300;
		color: var(--color-gray-800);
		margin-bottom: var(--space-m);
	}

	.page-header {
		display: flex;
		flex-direction: column;
		margin-top: var(--space-xl);
	}

	.main-title {
		margin-top: var(--space-m);
		margin-bottom: 0;
		max-width: 1100px;
	}


	.company-name {
		margin: 0 0.6rem 0 0.3rem;
	}

	.essays-section {
		grid-area: essays;
	}

	.patterns-section {
		grid-area: patterns;
	}

	.patterns-grid {
		margin-left: -1.4rem;
	}

	.library-section {
		grid-area: library;
	}

	.essays-grid,
	.books-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		grid-gap: var(--space-2xs);
	}

	.books-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		grid-gap: var(--space-2xs);
		margin: 0;
	}
	/* 入场渐显上浮 —— Hero 标题/bio + 各 section 按 DOM 顺序错落浮入。
	   克制：只动一次(进页面)，0.55s ease-out，y+16px。Maggie 调性。 */
	.reveal {
		opacity: 0;
		transform: translateY(16px);
		will-change: opacity, transform;
	}

	.reveal.in {
		opacity: 1;
		transform: none;
		transition:
			opacity 0.55s ease-out,
			transform 0.55s ease-out;
	}

	/* 无障碍 + 品质：用户关了动效就直接显示，不浮不渐 */
	@media (prefers-reduced-motion: reduce) {
		.reveal,
		.reveal.in {
			opacity: 1;
			transform: none;
			transition: none;
		}
	}
</style>

<script>
	import { onPageLifecycle } from "../utils/viewTransitionLifecycle";

	onPageLifecycle(() => {
		// 尊重 reduced-motion：直接全显，不挂动画
		const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
		const els = Array.from(document.querySelectorAll<HTMLElement>(".reveal"));
		if (prefersReduced) {
			els.forEach((el) => el.classList.add("in"));
			return;
		}
		// DOM 顺序即视觉顺序：第 i 个延迟 i*70ms 浮入
		els.forEach((el, i) => {
			el.style.transitionDelay = `${i * 70}ms`;
		});
		// 双 rAF 确保初始态(opacity0)先渲染一帧，再触发 transition
		requestAnimationFrame(() =>
			requestAnimationFrame(() => els.forEach((el) => el.classList.add("in"))),
		);

		// 清理：离开页面时移除 delay，避免 view-transition 残留
		return () => els.forEach((el) => {
			el.style.transitionDelay = "";
			el.classList.remove("in");
		});
	});
</script>
