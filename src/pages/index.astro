---
import { getCollection } from "astro:content";
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import Spacer from "../components/mdx/Spacer.astro";
import Title1 from "../components/mdx/typography/Title1.astro";
import SmallTitle2 from "../components/mdx/typography/SmallTitle2.astro";
import BookCard from "../components/cards/BookCard.astro";
import SkillCard from "../components/cards/SkillCard.astro";
import PageWrapper from "../components/layouts/PageWrapper.astro";
import newsItems from "../data/news.json";
import skillsData from "../data/skills.json";

const books = await getCollection("books");

// 首页"Recent Chapters" 区：跨书最近更新的 4 章。essays / notes / patterns
// collection 均为空（站点没用这些类型），所以 Maggie 原版的 Essays 区
// 改成"最近章节流"——指向同源数据，本质和 /garden 子页一致但只取 4 条。
const allChapters = await getCollection("chapters");
const allBooksList = books;
const bookBySlugMap = new Map(
	allBooksList.filter((b) => b.data.slug).map((b) => [b.data.slug!, b.data])
);
const recentChapters = [...allChapters]
	.sort((a, b) => {
		const ad = a.data.updated ?? a.data.startDate ?? new Date(0);
		const bd = b.data.updated ?? b.data.startDate ?? new Date(0);
		return new Date(bd).getTime() - new Date(ad).getTime();
	})
	.slice(0, 4)
	.map((c) => {
		const bookSlug = c.data.book;
		const chapterId = c.id.replace(bookSlug + "/", "").replace(/\.mdx$/, "");
		const book = bookBySlugMap.get(bookSlug);
		return {
			title: c.data.title,
			description: c.data.description,
			chapterLabel: c.data.chapterLabel ?? `第 ${c.data.chapterNumber} 章`,
			updated: c.data.updated ?? c.data.startDate,
			href: `/books/${bookSlug}/${chapterId}`,
			bookTitle: book?.title ?? bookSlug,
		};
	});

// 首页 News 只展示最新 6 条（按发布时间倒序）；完整列表见 /news
const HOMEPAGE_NEWS_LIMIT = 6;
const homepageNews = (newsItems as { title: string; url: string; date?: string }[])
	.slice()
	.sort((a, b) => {
		const ad = a.date ? new Date(a.date).getTime() : 0;
		const bd = b.date ? new Date(b.date).getTime() : 0;
		return bd - ad;
	})
	.slice(0, HOMEPAGE_NEWS_LIMIT);

// Featured skills on homepage: pick a curated cross-section across categories.
// 首页 Skills 精选 5 个：跨 5 个不同子类覆盖完整科研流水线。
// 完整 130 项见 /skills。
const HOMEPAGE_SKILL_PICKS = new Set([
	"analyze-results",       // 科研 · 数据分析
	"academic-researcher",   // 科研 · 写作流程与纪律
	"manuscript-optimizer",  // 科研 · 语言润色
	"mermaid-diagram",       // 科研 · 图表绘制
	"pdf",                   // 通用文档代表
]);
const featuredSkills = skillsData.filter((s) => HOMEPAGE_SKILL_PICKS.has(s.slug));
---

<Layout title="Chanw">
	<PageWrapper>
		<header class="page-header">
			<Title1 class="main-title">
				<b>Chanw&rsquo;s Garden</b>
				makes essays on doing research and the latest in AI.
			</Title1>
			<SmallTitle2>
				Empiricist, tool curator, and mediocre developer.<br />
				Currently exploring AI for empirical research at
				<a href="https://github.com/Lambenthan" target="_blank" rel="noopener noreferrer">github.com/Lambenthan</a>.
			</SmallTitle2>
		</header>

		<Spacer />

		<section>
			<a href="/garden">
				<h2 class="garden-title">The Garden</h2>
			</a>
			<div class="subheader">
				一座持续生长的学术花园 —— 长文、笔记、研究随想慢慢长出来。
			</div>
		</section>

		<section class="garden-section">
			<section class="essays-section">
				<a href="/garden" class="header-link">
					<h3 class="section-header">
						Recent Chapters
						<Icon name="heroicons:arrow-right" size={18} />
					</h3>
				</a>
				<div class="subheader">长文与书稿章节 —— 记录我对 AI 在各领域应用的所思所想。</div>
				<div class="recent-chapters">
					{
						recentChapters.map((c) => (
							<a class="chapter-row" href={c.href}>
								<h4 class="chapter-row-title">{c.title}</h4>
								{c.description && <p class="chapter-row-desc">{c.description}</p>}
								<div class="chapter-row-meta">
									<span>{c.chapterLabel}</span>
									<span class="dot">·</span>
									<span>{c.bookTitle}</span>
								</div>
							</a>
						))
					}
				</div>
			</section>

			<section style="grid-area: notes;">
				<a href="/news" class="header-link">
					<h3 class="section-header">
						News
						<Icon name="heroicons:arrow-right" size={18} />
					</h3>
				</a>
				<div class="subheader">
					AI 行业的最新动态 —— 模型发布、行业事件、热门开源项目，每日更新。
				</div>
				{
					homepageNews.map((item) => (
						<a href={item.url} target="_blank" rel="noopener noreferrer">
							<div class="index-note-card">
								<div class="icon">
									<Icon name="heroicons:bolt" size={20} />
								</div>
								<h3>{item.title}</h3>
							</div>
						</a>
					))
				}
			</section>

			<section class="patterns-section">
				<a href="/skills" class="header-link">
					<h3 class="section-header">
						Skills
						<Icon name="heroicons:arrow-right" size={18} />
					</h3>
				</a>
				<div class="subheader">
					策展过的 Claude Code skills —— 科研流水线置顶（数据分析、文献综述、图表、写作）；通用文档处理、设计、开发扩展跟后。
				</div>
				<div class="patterns-grid">
					{
						featuredSkills.map((s) => (
							<SkillCard
								slug={s.slug}
								repo={s.repo}
								path={s.path}
								ref={s.ref}
								descriptionZh={s.descriptionZh}
							/>
						))
					}
				</div>
			</section>

			<section class="library-section">
				<a href="/library" class="header-link">
					<h3 class="section-header">
						Library
						<Icon name="heroicons:arrow-right" size={18} />
					</h3>
				</a>
				<div class="subheader">我自己写的书。</div>
				<div class="books-grid">
					{
						books
							.slice(0, 8)
							.map((book) => (
								<BookCard
									small
									subtitle={book.data.subtitle}
									cover={book.data.cover}
									title={book.data.title}
									author={book.data.author}
									link={book.data.link}
								/>
							))
					}
				</div>
			</section>
		</section>
	</PageWrapper>
</Layout>

<style>
	.readmore-link {
		display: inline-flex;
		align-items: center;
		font-weight: 400;
		color: var(--color-crimson);
	}

	.readmore-link [data-icon] {
		transition: all 0.3s ease-in-out;
		position: relative;
		top: 2px;
		margin-left: var(--space-3xs);
	}

	.readmore-link:hover {
		color: var(--color-bright-crimson);
		cursor: pointer;
	}

	.readmore-link:hover [data-icon] {
		margin-left: var(--space-2xs);
		color: var(--color-sea-blue);
	}

	/* Recent Chapters mini-feed: 4 条最近章节，纵向 stack，
	   每条一个 row，hover 整条变 sea-blue。链接整 row 可点击。 */
	.recent-chapters {
		display: flex;
		flex-direction: column;
	}

	.chapter-row {
		display: block;
		padding: var(--space-xs) 0 var(--space-s);
		border-bottom: 1px solid var(--color-tinted-cream);
		text-decoration: none;
		color: inherit;
		transition: background-color 0.2s ease;
	}

	.chapter-row:hover {
		background: color-mix(in srgb, var(--color-sea-blue) 4%, transparent);
	}

	.chapter-row-title {
		font-family: var(--font-serif);
		font-size: calc(var(--font-size-base) * 1.05);
		font-weight: 500;
		color: var(--color-gray-800);
		margin: 0 0 var(--space-3xs);
		line-height: 1.3;
		transition: color 0.2s ease;
	}

	.chapter-row:hover .chapter-row-title {
		color: var(--color-sea-blue);
	}

	.chapter-row-desc {
		font-family: var(--font-body);
		font-size: var(--font-size-sm);
		color: var(--color-gray-700);
		line-height: 1.55;
		margin: 0 0 var(--space-3xs);
	}

	.chapter-row-meta {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-gray-500);
		font-variant-numeric: tabular-nums;
	}

	.chapter-row-meta .dot {
		margin: 0 0.35em;
		color: var(--color-gray-400);
	}

	.index-note-card {
		display: flex;
		padding: var(--space-xs) 0 1.2rem;
		border-bottom: 1px solid var(--color-tinted-cream);
		transition: all 0.3s ease-in-out;
	}

	.index-note-card .icon {
		position: relative;
		top: 5px;
		flex-shrink: 0;
		color: var(--color-sea-blue);
	}

	.index-note-card h3 {
		color: var(--color-gray-800);
		transition: all 0.3s ease-in-out;
		font-family: var(--font-body);
		font-size: var(--font-size-base);
		font-weight: 400;
		line-height: var(--leading-snug);
		margin-left: var(--space-xs);
		transition: all 0.3s ease-in-out;
	}

	.index-note-card:hover {
		border-bottom: 1px solid var(--color-sea-blue);
		transform: scale3d(1.02, 1.02, 1.02);
	}

	.index-note-card:hover h3 {
		color: var(--color-crimson);
	}

	.garden-title {
		font-size: var(--font-size-2xl);
		font-family: var(--font-serif);
		color: var(--color-gray-800);
		font-weight: 100;
		line-height: var(--leading-snug);
		margin: var(--space-xs) 0 var(--space-2xs);
		transition: all 0.3s ease-in-out;
	}

	.garden-section {
		margin: var(--space-xl) 0 var(--space-s);
		display: grid;
		grid-gap: var(--space-xl);
		grid-template-columns: 1fr 1fr 1fr;
		grid-template-rows: auto;
		grid-template-areas:
			"essays essays notes"
			"patterns library library";
	}

	@media (max-width: 768px) {
		.garden-section {
			grid-gap: var(--space-s);
		}
	}

	@media (max-width: 640px) {
		.garden-section {
			grid-template-columns: 1fr;
			grid-gap: var(--space-l);
			grid-template-rows: auto;
			grid-template-areas: "essays" "notes" "patterns" "library";
		}
	}

	.section-header {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: 600;
		color: var(--color-gray-800);
		display: flex;
		align-items: center;
		margin-bottom: var(--space-3xs);
	}

	.section-header [data-icon] {
		transition: all 0.3s ease-in-out;
		position: relative;
		top: 2px;
		margin-left: var(--space-3xs);
	}

	.header-link:hover .section-header {
		color: var(--color-bright-crimson);
	}

	.header-link:hover .section-header [data-icon] {
		margin-left: var(--space-2xs);
		color: var(--color-sea-blue);
	}

	.subheader {
		font-family: var(--font-sans);
		font-size: var(--font-size-base);
		font-weight: 300;
		color: var(--color-gray-800);
		margin-bottom: var(--space-m);
	}

	.page-header {
		display: flex;
		flex-direction: column;
		margin-top: var(--space-xl);
	}

	.main-title {
		margin-top: var(--space-m);
		margin-bottom: 0;
		max-width: 1100px;
	}


	.company-name {
		margin: 0 0.6rem 0 0.3rem;
	}

	.essays-section {
		grid-area: essays;
	}

	.patterns-section {
		grid-area: patterns;
	}

	.patterns-grid {
		margin-left: -1.4rem;
	}

	.library-section {
		grid-area: library;
	}

	.essays-grid,
	.books-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		grid-gap: var(--space-2xs);
	}

	.books-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
		grid-gap: var(--space-2xs);
		margin: 0;
	}
</style>
