---
import { Icon } from "astro-icon/components";

interface Props {
	slug: string;
	repo: string;
	path?: string;
	ref?: string;
	descriptionZh?: string | null;
}

const { slug, repo, path, ref, descriptionZh } = Astro.props;

const branch = ref || "main";
const resolvedPath = path || `skills/${slug}`;
const href = `https://github.com/${repo}/tree/${branch}/${resolvedPath}`;
---

<a href={href} target="_blank" rel="noopener noreferrer">
	<div class="skill-card">
		<Icon name="heroicons:wrench-screwdriver" size={24} class="skill-icon" />
		<div>
			<h3>{slug}</h3>
			{descriptionZh && <p class="description">{descriptionZh}</p>}
			<div class="metadata-container">
				<span>Skill</span>
				<svg width="4px" height="4px">
					<circle r="2" cx="2" cy="2" fill="var(--color-gray-400)"></circle>
				</svg>
				<span class="repo">{repo}</span>
			</div>
		</div>
	</div>
</a>

<style>
	.metadata-container {
		display: flex;
		flex-direction: row;
		flex-wrap: wrap;
		align-items: center;
		margin-left: var(--space-xs);
		margin-top: 4px;
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		color: var(--color-gray-500);
		font-weight: 400;
	}

	.skill-card .metadata-container svg {
		margin: 0 0.4rem;
		position: relative;
		top: 1px;
	}

	.repo {
		font-family: var(--font-sans);
	}

	.description {
		font-size: var(--font-size-xs);
		color: var(--color-gray-500);
		font-family: var(--font-sans);
		font-weight: 400;
		margin-left: var(--space-xs);
		margin-top: var(--space-2xs);
		padding-right: var(--space-s);
		line-height: var(--leading-snug);
	}

	.skill-card {
		display: flex;
		flex-direction: row;
		padding: var(--space-xs);
		margin: 0 var(--space-xs) var(--space-xs) 0;
		border-radius: var(--border-radius-base);
		border: 1px solid var(--color-cream);
		transition: all 0.3s ease-in-out;
		will-change: transform, background-color, box-shadow;
		cursor: pointer;
	}

	.skill-card h3 {
		color: var(--color-gray-800);
		transition: color 0.3s ease-in-out;
		will-change: transform;
		font-family: var(--font-body);
		font-size: var(--font-size-base);
		font-weight: 400;
		line-height: var(--leading-snug);
		margin-left: var(--space-xs);
	}

	.skill-card :global(.skill-icon) {
		position: relative;
		top: 4px;
		flex-shrink: 0;
		color: var(--color-sea-blue);
	}

	.skill-card:hover {
		transform: scale3d(1.02, 1.02, 1.02);
		background: var(--color-light-cream);
		box-shadow: var(--box-shadow-sm);
		border: 1px solid var(--color-tinted-cream);
	}

	.skill-card:hover h3 {
		color: var(--color-crimson);
	}
</style>
