<article class="prose-wrapper">
	<slot />
</article>

<style>
	.prose-wrapper {
		display: grid;
		grid-template-columns: 1fr min(72ch, 100%) 1fr;
		counter-reset: footnote-counter;
		font-size: var(--font-size-base);
	}

	.prose-wrapper > :global(*) {
		grid-column: 2;
	}

	.prose-wrapper > :global(p) {
		font-size: var(--font-size-base);
		line-height: 1.75;
		margin-bottom: var(--space-s);
	}

	@media (max-width: 767px) {
		.prose-wrapper > :global(p) {
			line-height: 1.65;
		}
	}

	.prose-wrapper > :global(p.subtext) {
		font-size: calc(var(--font-size-sm) * 1.1);
		line-height: var(--leading-loose);
	}

	.prose-wrapper > :global(h1) {
		font-size: var(--font-size-2xl);
		margin: var(--space-2xl) 0 var(--space-m);
	}

	.prose-wrapper > :global(h2) {
		font-size: var(--font-size-xl);
		margin: var(--space-xl) 0 var(--space-m);
		line-height: var(--leading-base);
	}

	.prose-wrapper :global(h2.micro) {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		color: var(--color-bright-crimson);
		margin: 0 0 var(--space-s);
		line-height: var(--leading-base);
		text-transform: uppercase;
		font-weight: 700;
		letter-spacing: 0.04rem;
	}

	.prose-wrapper :global(h3) {
		font-size: calc(var(--font-size-lg) / 1.1);
		font-weight: 300;
		line-height: var(--leading-base);
		margin: var(--space-m) 0 var(--space-s);
	}

	.prose-wrapper :global(h4) {
		font-size: var(--font-size-base);
		font-weight: 700;
		margin: var(--space-s) 0 var(--space-xs);
	}

	/* Remove top margin when headings are directly adjacent to each other within prose */
	.prose-wrapper :global(h1 + h2),
	.prose-wrapper :global(h2 + h3),
	.prose-wrapper :global(h3 + h4),
	.prose-wrapper :global(h4 + h5),
	.prose-wrapper :global(h5 + h6) {
		margin-top: 0;
	}

	/* · · · 分隔符（hr）紧跟标题时：分隔符自身的 margin-bottom 已经给足分节留白，
	   标题再叠一个 space-xl 顶距，两者相加会在分隔符和标题之间空出一大块。
	   分隔符后的标题顶距清零，让标题贴着分隔符的下边距，间距由 hr 单方控制。 */
	.prose-wrapper :global(hr + h2),
	.prose-wrapper :global(hr + h3) {
		margin-top: 0;
	}

	.prose-wrapper :global(ul),
	.prose-wrapper :global(ol) {
		padding: 0;
		margin-top: 0;
	}

	.prose-wrapper :global(ul) {
		list-style: none;
	}

	.prose-wrapper :global(ul > li) {
		margin-bottom: var(--space-xs);
		line-height: var(--leading-loose);
		margin-left: 2.5rem;
	}

	.prose-wrapper :global(ul > li::before) {
		content: "";
		display: inline-block;
		width: 24px;
		clear: both;
		height: 24px;
		margin-right: -1.5rem;
		background-image: url("/images/leaf-icon.svg");
		background-size: contain;
		background-repeat: no-repeat;
		position: relative;
		top: 4px;
		right: 2.5rem;
	}

	.prose-wrapper :global(ol > li) {
		margin-bottom: var(--space-xs);
		line-height: var(--leading-looser);
		margin-left: 2.5rem;
	}

	/* 章节分隔符 —— 三点书签（· · ·）。
	   替代 Maggie 原版的橙色 3px 实心色块。
	   语汇上跟 LXGW WenKai 古典书风对齐，色相中性，
	   视觉重量低于 H2 dotted hairline，仅做章内过渡。
	   实现：hr 本身藏掉，靠 ::before 注入三点 Times 字符 */
	.prose-wrapper :global(hr) {
		border: none;
		background: none;
		height: auto;
		width: auto;
		margin: var(--space-l) auto;
		text-align: center;
		overflow: visible;
	}

	.prose-wrapper :global(hr)::before {
		content: "·  ·  ·";
		font-family: "TNR Numerals", "Times New Roman", serif;
		font-size: var(--font-size-md);
		color: var(--color-gray-400);
		letter-spacing: 0.6em;
		line-height: 1;
		display: inline-block;
	}

	/* Blockquote ── 用作"轻引用、定义、内嵌说明"，跟正文同字号同
	   颜色，仅靠左侧细 sea-blue 线条 + 1em 缩进做视觉区分。
	   Maggie 原版的居中大字 + 上下装饰短线（pull quote）拉风格调
	   不适合学术正文里嵌的 inline 说明，去掉。
	   王阳明 / 苏轼 / 顾炎武等"原文摘录"用 <BlockquoteCitation>
	   单独组件，不走这条 CSS。 */
	.prose-wrapper :global(blockquote) {
		margin: var(--space-s) 0;
		padding: 0 0 0 var(--space-s);
		border-left: 2px solid var(--color-tinted-cream);
		color: var(--color-gray-700);
	}

	.prose-wrapper :global(blockquote > p) {
		margin: 0;
		font-size: inherit;
		line-height: inherit;
	}

	.prose-wrapper :global(blockquote > p + p) {
		margin-top: var(--space-2xs);
	}

	@media screen and (max-width: 767px) {
		.prose-wrapper :global(h1) {
			margin: var(--space-xl) 0 var(--space-m);
		}

		.prose-wrapper :global(h2) {
			margin: var(--space-l) 0 var(--space-s);
		}

		.prose-wrapper :global(hr) {
			margin: var(--space-l) auto;
		}
	}

	/* Data tables (markdown pipe tables). Visual: block-centered with auto width,
	   cream header band, subtle zebra rows, all cell content centered, tabular numerics. */
	.prose-wrapper :global(table) {
		width: auto;
		max-width: 100%;
		border-collapse: collapse;
		margin: var(--space-m) auto var(--space-l);
		font-family: var(--font-sans);
		font-size: calc(var(--font-size-base) / 1.15);
		line-height: var(--leading-snug);
		font-variant-numeric: tabular-nums;
	}

	.prose-wrapper :global(thead) {
		background: var(--color-cream);
	}

	.prose-wrapper :global(th) {
		text-align: center;
		font-weight: 700;
		color: var(--color-gray-800);
		padding: var(--space-2xs) var(--space-s);
		border-bottom: 2px solid var(--color-tinted-cream);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.04em;
	}

	.prose-wrapper :global(td) {
		text-align: center;
		padding: var(--space-2xs) var(--space-s);
		color: var(--color-gray-800);
		border-bottom: 1px solid var(--color-tinted-cream);
	}

	.prose-wrapper :global(tbody tr:nth-child(even)) {
		background: var(--color-light-cream);
	}

	.prose-wrapper :global(tbody tr:hover) {
		background: color-mix(in srgb, var(--color-sea-blue) 6%, transparent);
	}

	.prose-wrapper :global(table strong) {
		color: var(--color-crimson);
		font-weight: 700;
	}

	/* Mobile: 表格超出视口时允许水平滑动而不是被截断/压缩。
	   关键技巧：表格转 display: block，让它能横向 overflow；
	   tbody/thead/tr 保持原 display 让单元格仍按 table layout 排版。
	   桌面版（>768px）仍走标准 display: table，居中、宽度自适应。 */
	@media (max-width: 768px) {
		.prose-wrapper :global(table) {
			display: block;
			overflow-x: auto;
			-webkit-overflow-scrolling: touch;
			width: 100%;
			max-width: 100%;
			white-space: nowrap;
		}

		.prose-wrapper :global(table thead),
		.prose-wrapper :global(table tbody) {
			display: table;
			width: max-content;
			min-width: 100%;
		}
	}

	/* 学术示意图 video（替代 GIF）：autoplay loop muted playsinline，
	   视觉上跟 markdown 图片一样居中、响应式 max-width 100% */
	.prose-wrapper :global(video.academic-figure) {
		display: block;
		max-width: 100%;
		height: auto;
		margin: var(--space-m) auto var(--space-2xs);
		border-radius: var(--border-radius-sm, 4px);
	}

	/* KaTeX inline math: KaTeX 默认 1.21em 会让 $-0.317$ 等纯数字 inline
	   math 视觉上比周围 LXGW 中文 + Times 西文显著大一截。强制 1em，
	   让 inline 数字 / 公式 / 变量与正文同字号。display math（$$...$$）
	   仍走 1.21em 以保持"块级公式"的传统重量感。*/
	/* 强调下划线 <u>：手画书签式重点标注，区别于链接（链接是实色文字 + 细线）。
	   正文色不变，只在底部加一道略粗、半透明 crimson 的下划线，配合 offset，
	   读起来像在书上用笔划的重点，贴合 LXGW 古典书风。仅作强调，不可点击。 */
	.prose-wrapper :global(u) {
		text-decoration-line: underline;
		text-decoration-color: color-mix(in srgb, var(--color-crimson) 42%, transparent);
		text-decoration-thickness: 0.14em;
		text-underline-offset: 0.16em;
		text-decoration-skip-ink: none;
	}

	.prose-wrapper :global(.katex) {
		font-size: 1em;
	}

	.prose-wrapper :global(.katex-display > .katex) {
		font-size: 1.21em;
	}
</style>
