---
/**
 * SeriesNav — 多篇成系列的 essay 之间的上一篇 / 下一篇导航。
 * 视觉沿用 ChapterNav，但不依赖 books 集合（essay 没有书目录页），
 * 中间链接指向系列归属页（默认 /garden）。所有字段用字符串 prop 传，便于在 MDX 里直接写。
 */
import { Icon } from "astro-icon/components";

interface Props {
	prevHref?: string;
	prevLabel?: string;
	prevTitle?: string;
	nextHref?: string;
	nextLabel?: string;
	nextTitle?: string;
	indexHref?: string;
	indexLabel?: string;
}

const {
	prevHref,
	prevLabel,
	prevTitle,
	nextHref,
	nextLabel,
	nextTitle,
	indexHref = "/garden",
	indexLabel = "系列目录",
} = Astro.props;
---

<nav class="chapter-nav" aria-label="Series navigation">
	<div class="nav-grid">
		<div class="nav-left">
			{prevHref && (
				<a href={prevHref} class="nav-link">
					<span class="nav-direction">
						<Icon name="heroicons:arrow-left" size={14} />
						<span>{prevLabel ?? "上一篇"}</span>
					</span>
					<span class="nav-title">{prevTitle}</span>
				</a>
			)}
		</div>
		<div class="nav-center">
			<a href={indexHref} class="toc-link" title={indexLabel}>
				<Icon name="heroicons:list-bullet" size={16} />
				<span>{indexLabel}</span>
			</a>
		</div>
		<div class="nav-right">
			{nextHref && (
				<a href={nextHref} class="nav-link nav-right-link">
					<span class="nav-direction">
						<span>{nextLabel ?? "下一篇"}</span>
						<Icon name="heroicons:arrow-right" size={14} />
					</span>
					<span class="nav-title">{nextTitle}</span>
				</a>
			)}
		</div>
	</div>
</nav>

<style>
	.chapter-nav {
		max-width: 800px;
		margin: var(--space-2xl) auto var(--space-l);
		padding: var(--space-m) 0 0;
		border-top: 1px solid var(--color-tinted-cream);
	}

	.nav-grid {
		display: grid;
		grid-template-columns: 1fr auto 1fr;
		gap: var(--space-m);
		align-items: start;
	}

	.nav-left {
		justify-self: start;
		max-width: 280px;
	}

	.nav-right {
		justify-self: end;
		max-width: 280px;
		text-align: right;
	}

	.nav-center {
		justify-self: center;
		display: flex;
		align-items: center;
	}

	.nav-link {
		display: flex;
		flex-direction: column;
		gap: var(--space-3xs);
		text-decoration: none;
		transition: color 0.3s ease-in-out;
	}

	.nav-direction {
		display: inline-flex;
		align-items: center;
		gap: var(--space-3xs);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: bold;
		color: var(--color-gray-600);
		transition: color 0.3s ease-in-out;
	}

	.nav-title {
		font-family: var(--font-body);
		font-size: var(--font-size-sm);
		color: var(--color-gray-800);
		line-height: var(--leading-snug);
		transition: color 0.3s ease-in-out;
	}

	.nav-right-link {
		align-items: flex-end;
	}

	.nav-link:hover .nav-direction {
		color: var(--color-sea-blue);
	}

	.nav-link:hover .nav-title {
		color: var(--color-crimson);
	}

	.toc-link {
		display: inline-flex;
		align-items: center;
		gap: var(--space-3xs);
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.05em;
		font-weight: bold;
		color: var(--color-bright-crimson);
		text-decoration: none;
		padding: var(--space-3xs) var(--space-xs);
		border: 1px solid var(--color-tinted-cream);
		border-radius: var(--border-radius-base);
		transition: all 0.3s ease-in-out;
	}

	.toc-link:hover {
		background: var(--color-light-cream);
		border-color: var(--color-crimson);
	}

	@media (max-width: 640px) {
		.nav-grid {
			grid-template-columns: 1fr;
			gap: var(--space-s);
		}

		.nav-left,
		.nav-right,
		.nav-center {
			justify-self: stretch;
			max-width: none;
			text-align: left;
		}

		.nav-right-link {
			align-items: flex-start;
		}
	}
</style>
