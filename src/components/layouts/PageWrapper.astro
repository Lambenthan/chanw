---
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
// 用 div 而非 main：Layout.astro 已提供唯一的 <main> landmark，
// 这里再套一个 <main> 会造成嵌套双 main（无效 HTML + a11y landmark 违规）。
---

<div class:list={["page-wrapper", className]}>
	<slot />
</div>

<style>
	.page-wrapper {
		max-width: 1420px;
		margin: var(--space-l) auto var(--space-3xl);
		padding: 0 var(--space-l);
	}
	/* 14" and 13" MacBook Pro screens (1280–1512px logical width) need extra side breathing room */
	@media (min-width: 769px) and (max-width: 1512px) {
		.page-wrapper {
			padding: 0 calc(var(--space-l) + 2rem);
		}
	}
	@media (max-width: 768px) {
		.page-wrapper {
			margin: var(--space-s) auto var(--space-2xl);
			padding: 0 var(--space-m);
		}
	}
	@media (max-width: 576px) {
		.page-wrapper {
			margin: var(--space-xs) auto var(--space-xl);
			padding: 0 var(--space-xs);
		}
	}
</style>
