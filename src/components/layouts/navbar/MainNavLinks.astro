---
import UnderlineHoverLink from "../../mdx/UnderlineHoverLink.astro";
---

<div class="main" role="navigation" aria-label="Main">
	<div class="outside-dropdown">
		<UnderlineHoverLink href="/library">Library</UnderlineHoverLink>
		<UnderlineHoverLink href="/news">News</UnderlineHoverLink>
		<UnderlineHoverLink href="/skills">Skills</UnderlineHoverLink>
		<UnderlineHoverLink href="/about">About</UnderlineHoverLink>
	</div>
</div>

<style>
	.main {
		display: flex;
		flex-shrink: 0;
	}

	.outside-dropdown {
		display: flex;
		align-items: baseline;
	}

	.outside-dropdown :global(.link-container) {
		margin-left: var(--space-s);
		top: 1px;
		left: 3px;
	}

	.outside-dropdown :global(.styled-link span) {
		font-size: var(--font-size-xs);
		font-family: var(--font-sans);
		color: var(--color-gray-800);
	}

	@media screen and (max-width: 550px) {
		.main {
			display: none;
		}
	}
</style>
