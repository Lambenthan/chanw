---
/**
 * 章节内 H3 标题（### 1.2.1 ...）专用。ElegantBook 学术风。
 *
 * 视觉跟 ChapterTitle2 同语言但明确"小一级"：
 * - H2 = 实心 sea-blue 徽章（白字）
 * - H3 = 镂空 sea-blue 徽章（sea-blue 字，仅边框）
 * 这种"实心 vs 镂空"对应"section vs subsection"是学术教科书惯例
 *
 * 字号也小一档，无底线（避免视觉过重）。
 */
const { id } = Astro.props;
---

<h3 class="chapter-h3" id={id}><slot /></h3>

<style>
  .chapter-h3 {
    /* gwern.net 风：H3 = 1.2em of body，比 H2 (--font-size-md) 略小，
       明确从属层级。使用 calc 保证流体字号跟随 body */
    font-size: calc(var(--font-size-base) * 1.15);
    font-family: var(--font-serif);
    color: var(--color-gray-800);
    font-weight: 400;
    line-height: 1.3;
    margin: var(--space-m) 0 var(--space-2xs);
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4em;
    transition: color 0.3s ease;
    scroll-margin-top: var(--space-l);
  }

  /* 节号 ── 同 H2，inline sea-blue Times Numerals 无框无底
     H3 与 H2 共用一套节号视觉语言，靠字号自然区分层级 */
  .chapter-h3 :global(.section-number) {
    display: inline;
    background: none;
    border: none;
    color: var(--color-sea-blue);
    font-family: "TNR Numerals", "Times New Roman", serif;
    font-weight: 500;
    font-size: 1em;
    line-height: inherit;
    padding: 0;
    margin-right: 0.2em;
    letter-spacing: 0;
    font-variant-numeric: tabular-nums;
  }
</style>
