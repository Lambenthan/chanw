---
/**
 * 章节内 H3 标题（### 0.1.1 ...）专用。
 *
 * 比 ChapterTitle2 小一档，无左 accent 条（避免视觉过度），节号同样降级。
 */
const { id } = Astro.props;
---

<h3 class="chapter-h3" id={id}><slot /></h3>

<style>
  .chapter-h3 {
    font-size: 1.25rem;
    font-family: var(--font-serif);
    color: var(--color-gray-800);
    font-weight: 400;
    line-height: 1.3;
    margin: var(--space-m) 0 var(--space-2xs);
    transition: all 0.3s ease-in-out;
    scroll-margin-top: var(--space-l);
  }

  @media (max-width: 1024px) {
    .chapter-h3 {
      font-size: 1.15rem;
    }
  }

  @media (max-width: 640px) {
    .chapter-h3 {
      font-size: 1.05rem;
    }
  }

  .chapter-h3 :global(.section-number) {
    font-family: "TNR Numerals", "Times New Roman", serif;
    font-weight: 400;
    color: var(--color-gray-500);
    font-size: 0.85em;
    margin-right: 0.4em;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }
</style>
