---
/**
 * 章节内 H2 标题（## 1.2 ...）专用。ElegantBook 学术风：
 *
 * - 节号 1.2 装进 sea-blue 圆角徽章（深底白字）做视觉锚点
 * - 标题正文跟在徽章右边，正常衬线
 * - H2 底下一道细 hairline 做分节（不再用左竖条，避免和
 *   定义框 / 定理框 / 误区框的左竖条糊成一坨）
 * - 中文 short heading 字号合理化，移动端不再换 3-4 行
 *
 * 节号 wrap 由 [chapter].astro 的脚本完成（扫 .chapter-h2 → 把
 * 开头数字包成 <span class="section-number">）。
 */
const { id } = Astro.props;
---

<h2 class="chapter-h2" id={id}><slot /></h2>

<style>
  .chapter-h2 {
    /* gwern.net 风：H2 = 1.4em of body（参考 gwern.net/static/css/initial.css），
       走我们的 --font-size-md token (25-28.6px) 等价 */
    font-size: var(--font-size-md);
    font-family: var(--font-serif);
    color: var(--color-gray-800);
    font-weight: 400;
    line-height: 1.25;
    /* gwern 风学术虚线：H2 底下淡淡的 dotted hairline，
       视觉重量比 solid border 低一档，academic listing 锚点 */
    margin: var(--space-m) 0 var(--space-s);
    padding-bottom: var(--space-2xs);
    border-bottom: 1px dotted var(--color-gray-300);
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.4em;
    transition: color 0.3s ease;
    scroll-margin-top: var(--space-l);
  }

  /* 节号 ── 学术教科书惯例：sea-blue inline Times Numerals，
     无框无背景，靠颜色 + 衬线区分；视觉重量比 badge 低一档 */
  .chapter-h2 :global(.section-number) {
    display: inline;
    background: none;
    border: none;
    color: var(--color-sea-blue);
    font-family: "TNR Numerals", "Times New Roman", serif;
    font-weight: 500;
    font-size: 1em;
    line-height: inherit;
    padding: 0;
    margin-right: 0.2em;
    letter-spacing: 0;
    font-variant-numeric: tabular-nums;
  }
</style>
