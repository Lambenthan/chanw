---
/**
 * 章节内 H2 标题（## 1.2 ...）专用。ElegantBook 学术风：
 *
 * - 节号 1.2 装进 sea-blue 圆角徽章（深底白字）做视觉锚点
 * - 标题正文跟在徽章右边，正常衬线
 * - H2 底下一道细 hairline 做分节（不再用左竖条，避免和
 *   定义框 / 定理框 / 误区框的左竖条糊成一坨）
 * - 中文 short heading 字号合理化，移动端不再换 3-4 行
 *
 * 节号 wrap 由 [chapter].astro 的脚本完成（扫 .chapter-h2 → 把
 * 开头数字包成 <span class="section-number">）。
 */
const { id } = Astro.props;
---

<h2 class="chapter-h2" id={id}><slot /></h2>

<style>
  .chapter-h2 {
    font-size: 1.625rem;
    font-family: var(--font-serif);
    color: var(--color-gray-800);
    font-weight: 400;
    line-height: 1.3;
    margin: var(--space-xl) 0 var(--space-m);
    padding-bottom: var(--space-2xs);
    border-bottom: 1px solid var(--color-tinted-cream);
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.45em;
    transition: all 0.3s ease-in-out;
    scroll-margin-top: var(--space-l);
  }

  @media (max-width: 1024px) {
    .chapter-h2 {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .chapter-h2 {
      font-size: 1.3rem;
    }
  }

  /* 节号徽章 ── 深 sea-blue 圆角小色块，白字 Times 衬线 */
  .chapter-h2 :global(.section-number) {
    display: inline-block;
    background: var(--color-sea-blue);
    color: var(--color-white);
    font-family: "TNR Numerals", "Times New Roman", serif;
    font-weight: 400;
    font-size: 0.75em;
    line-height: 1.2;
    padding: 0.15em 0.5em;
    border-radius: 4px;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
    /* baseline 微调，让徽章中线和标题中文字基本对齐 */
    transform: translateY(-0.12em);
  }
</style>
