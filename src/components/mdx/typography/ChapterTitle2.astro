---
/**
 * 章节内 H2 标题（## 0.1 ...）专用。
 *
 * 与 Maggie 原 Title2 区别：
 * - 中文 short heading（10-25 字）的字号合理化，移动端不再换 3-4 行
 * - 节号前缀（0.1 / 1.2 等）视觉降级为浅灰、细 Times、小 1 档
 * - 左侧 4px sea-blue accent 条，建立学术分节视觉锚
 * - 行高紧一档
 *
 * 实现：用正则把 slot 文本前缀 (N.M[空格]) 拆出来分别染色。
 * 数字 + 西文标点用 Times New Roman（站点 TNR Numerals 字体栈
 * 通过 unicode-range 自动接管 ASCII 范围）。
 */
const { id } = Astro.props;
---

<h2 class="chapter-h2" id={id}><slot /></h2>

<style>
  .chapter-h2 {
    /* desktop: 1.625rem (~26px on 16px base) */
    font-size: 1.625rem;
    font-family: var(--font-serif);
    color: var(--color-gray-800);
    font-weight: 400;
    line-height: 1.25;
    margin: var(--space-l) 0 var(--space-s);
    padding-left: var(--space-xs);
    border-left: 4px solid var(--color-sea-blue);
    transition: all 0.3s ease-in-out;
    scroll-margin-top: var(--space-l);
  }

  @media (max-width: 1024px) {
    .chapter-h2 {
      font-size: 1.5rem;
    }
  }

  @media (max-width: 640px) {
    .chapter-h2 {
      font-size: 1.3rem;
      padding-left: var(--space-2xs);
      border-left-width: 3px;
    }
  }

  /* 节号前缀（0.1 / 1.2 / 2.3.4 等）—— 用 ::first-line 不行（first-line 是
     渲染行，不是语义），改用 JS 在 [chapter].astro 里加 span 包装。这里
     提前定义样式，等 JS 把数字部分包成 .section-number 后生效。 */
  .chapter-h2 :global(.section-number) {
    font-family: "TNR Numerals", "Times New Roman", serif;
    font-weight: 400;
    color: var(--color-gray-500);
    font-size: 0.85em;
    margin-right: 0.4em;
    letter-spacing: 0.02em;
    font-variant-numeric: tabular-nums;
  }
</style>
