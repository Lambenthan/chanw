---
interface Props {
	title?: string;
}

const { title } = Astro.props;
---

<aside class="method-card">
	<header class="card-header">
		<span class="card-label">方法卡</span>
		{title && <span class="card-title">{title}</span>}
	</header>
	<div class="card-body">
		<slot />
	</div>
</aside>

<style>
	.method-card {
		margin: var(--space-m) 0;
		padding: var(--space-s) var(--space-m);
		border: 1px solid var(--color-tinted-cream);
		background: var(--color-light-cream);
		border-radius: var(--border-radius-base);
		box-shadow: var(--box-shadow-sm);
	}

	.card-header {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-xs);
		margin-bottom: var(--space-xs);
		padding-bottom: var(--space-2xs);
		border-bottom: 1px solid var(--color-tinted-cream);
	}

	.card-label {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		font-weight: 700;
		color: var(--color-purple);
		flex-shrink: 0;
	}

	.card-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-base);
		font-weight: 400;
		color: var(--color-gray-800);
		line-height: var(--leading-snug);
	}

	/* Style the 4-field structure as a definition list with sea-blue labels.
	   Content authors write the structure as plain markdown bold-prefixed paragraphs;
	   the visual transformation is done via CSS targeting <strong> at paragraph start. */
	.card-body :global(p) {
		font-size: calc(var(--font-size-base) / 1.05);
		line-height: var(--leading-base);
		color: var(--color-gray-800);
		margin: 0 0 var(--space-2xs) 0;
		padding-left: var(--space-s);
		text-indent: calc(-1 * var(--space-s));
	}

	.card-body :global(p:last-child) {
		margin-bottom: 0;
	}

	.card-body :global(p > strong:first-child) {
		font-family: var(--font-sans);
		font-size: var(--font-size-xs);
		text-transform: uppercase;
		letter-spacing: 0.04em;
		color: var(--color-medium-sea-blue);
		font-weight: 700;
		display: inline-block;
		min-width: 5rem;
		margin-right: var(--space-2xs);
	}
</style>
