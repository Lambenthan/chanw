---
interface Props {
	title?: string;
	number?: string;
}

const { title, number } = Astro.props;
const heading = number ? `定义 ${number}` : "定义";
---

<aside class="academic-box definition-box">
	<header class="box-header">
		<span class="box-label">{heading}</span>
		{title && <span class="box-title">{title}</span>}
	</header>
	<div class="box-body">
		<slot />
	</div>
</aside>

<style>
	.academic-box {
		position: relative;
		margin: var(--space-m) 0;
		padding: var(--space-s) var(--space-m) var(--space-s) var(--space-m);
		border-left: 3px solid var(--color-sea-blue);
		background: var(--color-light-cream);
		border-radius: 0 var(--border-radius-base) var(--border-radius-base) 0;
		box-shadow: var(--box-shadow-sm);
	}

	.box-header {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-xs);
		margin-bottom: var(--space-2xs);
		padding-bottom: var(--space-2xs);
		border-bottom: 1px solid var(--color-tinted-cream);
	}

	.box-label {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-medium-sea-blue);
		flex-shrink: 0;
		/* 不用 uppercase / letter-spacing：CJK "定义" 加 letter-spacing
		   会出现"定 义"可见间隙，破坏中文排版美感 */
	}

	.box-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-gray-800);
		line-height: var(--leading-snug);
	}

	.box-body :global(p) {
		font-size: calc(var(--font-size-base) / 1.05);
		line-height: 1.7;
		color: var(--color-gray-800);
		margin: 0 0 var(--space-s) 0;
	}

	.box-body :global(p:last-child) {
		margin-bottom: 0;
	}

	/* Display math inside box：跟正文同字号（1em），不放大；
	   只靠居中 + 周围 white space 强调"这是一行公式" */
	.box-body :global(.katex-display) {
		margin: var(--space-s) 0;
	}

	.box-body :global(.katex-display > .katex) {
		font-size: 1em;
	}
</style>
