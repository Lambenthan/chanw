---
interface Props {
	title?: string;
	number?: string;
	kind?: "theorem" | "proposition" | "lemma" | "corollary";
}

const { title, number, kind = "theorem" } = Astro.props;

const LABEL_MAP = {
	theorem: "定理",
	proposition: "命题",
	lemma: "引理",
	corollary: "推论",
};
const heading = number ? `${LABEL_MAP[kind]} ${number}` : LABEL_MAP[kind];
---

<aside class="academic-box theorem-box">
	<header class="box-header">
		<span class="box-label">{heading}</span>
		{title && <span class="box-title">{title}</span>}
	</header>
	<div class="box-body">
		<slot />
	</div>
</aside>

<style>
	.academic-box {
		position: relative;
		margin: var(--space-m) 0;
		padding: var(--space-s) var(--space-m) var(--space-s) var(--space-m);
		border-left: 3px solid var(--color-crimson);
		background: var(--color-light-cream);
		border-radius: 0 var(--border-radius-base) var(--border-radius-base) 0;
		box-shadow: var(--box-shadow-sm);
	}

	.box-header {
		display: flex;
		flex-wrap: wrap;
		align-items: baseline;
		gap: var(--space-xs);
		margin-bottom: var(--space-2xs);
		padding-bottom: var(--space-2xs);
		border-bottom: 1px solid var(--color-tinted-cream);
	}

	.box-label {
		font-family: var(--font-sans);
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-crimson);
		flex-shrink: 0;
		/* 不用 uppercase / letter-spacing：CJK 中文标签会出现可见字间隙 */
	}

	.box-title {
		font-family: var(--font-serif);
		font-size: var(--font-size-sm);
		font-weight: 500;
		color: var(--color-gray-800);
		line-height: var(--leading-snug);
	}

	.box-body :global(p) {
		font-size: calc(var(--font-size-base) / 1.05);
		line-height: 1.7;
		color: var(--color-gray-800);
		margin: 0 0 var(--space-s) 0;
		font-style: italic;
	}

	.box-body :global(p:last-child) {
		margin-bottom: 0;
	}

	.box-body :global(.katex-display) {
		margin: var(--space-s) 0;
	}

	.box-body :global(.katex-display > .katex) {
		font-size: 1em;
	}
</style>
