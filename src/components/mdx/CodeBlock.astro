---
/**
 * 代码块折叠包裹。注册到 [chapter].astro 的 components 表里替换 MDX 的
 * 默认 pre 渲染，让所有围栏代码块自动变成可折叠面板。
 *
 * 视觉：参考 src/components/mdx/Accordion.astro 的浅海蓝色系
 *   - 折叠态：浅海蓝底 + 左 6px 实线 accent
 *   - 展开态：白底 + 浅海蓝边框
 *   - 配合 astro.config Shiki vitesse-light 主题，代码本身浅色
 */
import { Icon } from "astro-icon/components";

const { class: className, style, "data-language": dataLanguage } = Astro.props;

const lang = (dataLanguage ?? className?.match(/language-(\w+)/)?.[1] ?? "")
  .toString()
  .toLowerCase();
const LANG_LABEL: Record<string, string> = {
  r: "R",
  py: "Python",
  python: "Python",
  bash: "Bash",
  sh: "Shell",
  zsh: "Shell",
  shell: "Shell",
  js: "JavaScript",
  ts: "TypeScript",
  tsx: "TypeScript",
  jsx: "JavaScript",
  sql: "SQL",
  yaml: "YAML",
  yml: "YAML",
  json: "JSON",
  html: "HTML",
  css: "CSS",
  md: "Markdown",
  mdx: "MDX",
  tex: "LaTeX",
  latex: "LaTeX",
};
const label = LANG_LABEL[lang] ?? (lang ? lang.toUpperCase() : "Code");
---

<details class="codeblock">
  <summary class="codeblock-summary">
    <div class="codeblock-summary-left">
      <Icon
        name="heroicons:code-bracket"
        size={18}
        class="codeblock-icon"
      />
      <span class="codeblock-lang">{label}</span>
      <span class="codeblock-hint">代码片段</span>
    </div>
    <div class="codeblock-summary-right">
      <span class="codeblock-action codeblock-action-collapsed">展开</span>
      <span class="codeblock-action codeblock-action-expanded">收起</span>
      <Icon
        name="heroicons:chevron-down"
        size={18}
        class="codeblock-chevron"
      />
    </div>
  </summary>
  <div class="codeblock-body">
    <pre class={className} style={style}><slot /></pre>
  </div>
</details>

<style>
  .codeblock {
    margin: var(--space-m) 0;
    border-radius: 6px;
    /* 平滑动画 ── grid-template-rows 0fr → 1fr 是当代 details 折叠
       动画唯一兼容方案 */
    box-shadow: var(--box-shadow-sm);
  }

  .codeblock-summary {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-2xs);
    padding: var(--space-xs) var(--space-s);
    background: #f0f9f8; /* Maggie Accordion 同款浅海蓝底 */
    border: 1px solid #ade3e3;
    border-left: 6px solid var(--color-sea-blue);
    border-radius: 6px;
    color: var(--color-dark-sea-blue);
    cursor: pointer;
    list-style: none;
    transition: all 0.3s ease;
  }

  .codeblock-summary::-webkit-details-marker {
    display: none;
  }

  .codeblock-summary:hover {
    background: #dbf3f3;
  }

  .codeblock[open] > .codeblock-summary {
    border-radius: 6px 6px 0 0;
    border-left: 6px solid #ade3e3;
  }

  .codeblock-summary-left {
    display: flex;
    align-items: center;
    gap: var(--space-2xs);
    min-width: 0;
  }

  .codeblock-icon {
    flex-shrink: 0;
    color: var(--color-sea-blue);
  }

  .codeblock-lang {
    font-family: var(--font-sans);
    font-size: var(--font-size-sm);
    font-weight: 600;
    color: var(--color-dark-sea-blue);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .codeblock-hint {
    font-family: var(--font-sans);
    font-size: var(--font-size-xs);
    color: var(--color-medium-sea-blue);
    font-weight: 300;
  }

  .codeblock-summary-right {
    display: flex;
    align-items: center;
    gap: var(--space-3xs);
    transition: all 0.3s ease;
  }

  .codeblock-action {
    font-family: var(--font-sans);
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-medium-sea-blue);
  }

  /* 折叠时显示"展开"，展开时显示"收起" */
  .codeblock-action-expanded {
    display: none;
  }
  .codeblock[open] .codeblock-action-collapsed {
    display: none;
  }
  .codeblock[open] .codeblock-action-expanded {
    display: inline;
  }

  .codeblock-chevron {
    color: var(--color-medium-sea-blue);
    transition: transform 0.3s ease;
  }

  .codeblock[open] .codeblock-chevron {
    transform: rotate(180deg);
  }

  .codeblock-body {
    padding: var(--space-s) var(--space-m);
    background: var(--color-white);
    border: 1px solid #b8e5e8;
    border-top: none;
    border-radius: 0 0 6px 6px;
    box-shadow: var(--box-shadow-md);
  }

  .codeblock-body :global(pre) {
    margin: 0;
    border: none;
    padding: 0;
    box-shadow: none;
    background: transparent !important;
    /* 让 Shiki 的 vitesse-light 内联 bg 不抢镜，body 提供统一 cream-tinted 容器 */
  }

  @media (max-width: 768px) {
    .codeblock-hint {
      display: none;
    }
    .codeblock-action {
      display: none !important;
    }
  }
</style>

<script>
  // 平滑展开 / 收起动画。原生 <details> 切换是瞬时的，加 motion
  // 让它和 Maggie Accordion 同款手感。
  import { animate } from "motion";
  import { onPageLifecycle } from "../../utils/viewTransitionLifecycle";

  onPageLifecycle(() => {
    const blocks = document.querySelectorAll<HTMLDetailsElement>(".codeblock");
    const cleanup: (() => void)[] = [];

    blocks.forEach((details) => {
      const summary = details.querySelector<HTMLElement>(".codeblock-summary");
      const body = details.querySelector<HTMLElement>(".codeblock-body");
      if (!summary || !body) return;

      const handler = (e: Event) => {
        e.preventDefault();
        const isOpen = details.hasAttribute("open");

        if (!isOpen) {
          details.setAttribute("open", "");
          const target = body.scrollHeight;
          body.style.overflow = "hidden";
          body.style.height = "0";
          (animate as any)(
            body,
            { height: [`0px`, `${target}px`], opacity: [0, 1] },
            { duration: 0.28, easing: "ease-out" },
          ).then(() => {
            body.style.height = "auto";
            body.style.overflow = "";
          });
        } else {
          const current = body.scrollHeight;
          body.style.overflow = "hidden";
          body.style.height = `${current}px`;
          (animate as any)(
            body,
            { height: [`${current}px`, "0px"], opacity: [1, 0] },
            { duration: 0.22, easing: "ease-in" },
          ).then(() => {
            details.removeAttribute("open");
            body.style.height = "";
            body.style.opacity = "";
            body.style.overflow = "";
          });
        }
      };

      summary.addEventListener("click", handler);
      cleanup.push(() => summary.removeEventListener("click", handler));
    });

    return () => cleanup.forEach((fn) => fn());
  });
</script>
