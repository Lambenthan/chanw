---
/**
 * 代码块折叠包裹 v3 —— 简约学术 listing。
 *
 * 视觉哲学：代码是正文的"附注"，不是 UI 控件。
 * - 无外框（无四边边框、无圆角矩形容器感）
 * - summary 仅靠下方一条 hairline 与正文分隔，跟章节内 hr 同语汇
 * - 语言标签：Times italic + 行数元数据（"R · 23 行"），dark-sea-blue
 * - 折叠开关：纯 +/− 字符，sans，灰阶；不写"展开/收起"
 * - hover 整条变 sea-blue
 * - 代码体内：light-cream 浅底 + Times serif（继承全局 code font）
 */
const { class: className, style, "data-language": dataLanguage } = Astro.props;

const lang = (dataLanguage ?? className?.match(/language-(\w+)/)?.[1] ?? "")
  .toString()
  .toLowerCase();
const LANG_LABEL: Record<string, string> = {
  r: "R",
  py: "Python",
  python: "Python",
  bash: "Bash",
  sh: "Shell",
  zsh: "Shell",
  shell: "Shell",
  js: "JavaScript",
  ts: "TypeScript",
  tsx: "TypeScript",
  jsx: "JavaScript",
  sql: "SQL",
  yaml: "YAML",
  yml: "YAML",
  json: "JSON",
  html: "HTML",
  css: "CSS",
  md: "Markdown",
  mdx: "MDX",
  tex: "LaTeX",
  latex: "LaTeX",
  mermaid: "Mermaid",
  sas: "SAS",
};
const label = LANG_LABEL[lang] ?? (lang ? lang.toUpperCase() : "Code");
---

<details class="codeblock">
  <summary class="codeblock-summary">
    <span class="codeblock-meta">
      <span class="codeblock-lang">{label}</span>
      <span class="codeblock-lines" data-lines></span>
    </span>
    <span class="codeblock-toggle" aria-hidden="true"></span>
  </summary>
  <div class="codeblock-body">
    <pre class={className} style={style}><slot /></pre>
  </div>
</details>

<style>
  .codeblock {
    margin: var(--space-2xs) 0 var(--space-s);
  }

  .codeblock-summary {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding: var(--space-3xs) 0;
    cursor: pointer;
    list-style: none;
    color: var(--color-gray-600);
    border-bottom: 1px solid var(--color-tinted-cream);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .codeblock-summary::-webkit-details-marker {
    display: none;
  }

  .codeblock-summary:hover {
    border-bottom-color: var(--color-sea-blue);
    color: var(--color-sea-blue);
  }

  .codeblock-meta {
    display: inline-flex;
    align-items: baseline;
    gap: var(--space-2xs);
  }

  /* 语言标签：Times italic，学术 listing 锚点 */
  .codeblock-lang {
    font-family: "TNR Numerals", "Times New Roman", serif;
    font-style: italic;
    font-size: calc(var(--font-size-base) * 0.92);
    color: var(--color-dark-sea-blue);
    letter-spacing: 0.01em;
    line-height: 1.4;
  }

  .codeblock-summary:hover .codeblock-lang {
    color: var(--color-sea-blue);
  }

  /* 行数元数据：小号 sans，"· 23 行"形式 */
  .codeblock-lines {
    font-family: var(--font-sans);
    font-size: var(--font-size-xs);
    color: var(--color-gray-500);
    font-variant-numeric: tabular-nums;
  }

  .codeblock-lines:not(:empty)::before {
    content: " · ";
    color: var(--color-gray-400);
  }

  /* 折叠开关：纯字符 +/− */
  .codeblock-toggle {
    font-family: var(--font-sans);
    font-size: var(--font-size-base);
    color: var(--color-gray-500);
    line-height: 1;
    flex-shrink: 0;
    width: 1em;
    text-align: center;
  }

  .codeblock-toggle::before {
    content: "+";
  }

  .codeblock[open] .codeblock-toggle::before {
    content: "−";
  }

  .codeblock-body {
    padding: var(--space-2xs) 0 var(--space-xs);
  }

  .codeblock-body :global(pre) {
    margin: 0;
    border: none;
    padding: var(--space-s) var(--space-m);
    box-shadow: none;
    background: var(--color-light-cream) !important;
    border-radius: 4px;
  }
</style>

<script>
  import { animate } from "motion";
  import { onPageLifecycle } from "../../utils/viewTransitionLifecycle";

  onPageLifecycle(() => {
    const blocks = document.querySelectorAll<HTMLDetailsElement>(".codeblock");
    const cleanup: (() => void)[] = [];

    blocks.forEach((details) => {
      const summary = details.querySelector<HTMLElement>(".codeblock-summary");
      const body = details.querySelector<HTMLElement>(".codeblock-body");
      const linesEl = details.querySelector<HTMLElement>("[data-lines]");
      const pre = details.querySelector<HTMLElement>("pre");
      if (!summary || !body || !pre) return;

      // 统计非空行数注入到 .codeblock-lines
      if (linesEl) {
        const lineCount = (pre.textContent ?? "")
          .split("\n")
          .filter((l) => l.trim().length > 0).length;
        if (lineCount > 0) linesEl.textContent = `${lineCount} 行`;
      }

      const handler = (e: Event) => {
        e.preventDefault();
        const isOpen = details.hasAttribute("open");

        if (!isOpen) {
          details.setAttribute("open", "");
          const target = body.scrollHeight;
          body.style.overflow = "hidden";
          body.style.height = "0";
          (animate as any)(
            body,
            { height: [`0px`, `${target}px`], opacity: [0, 1] },
            { duration: 0.28, easing: "ease-out" },
          ).then(() => {
            body.style.height = "auto";
            body.style.overflow = "";
          });
        } else {
          const current = body.scrollHeight;
          body.style.overflow = "hidden";
          body.style.height = `${current}px`;
          (animate as any)(
            body,
            { height: [`${current}px`, "0px"], opacity: [1, 0] },
            { duration: 0.22, easing: "ease-in" },
          ).then(() => {
            details.removeAttribute("open");
            body.style.height = "";
            body.style.opacity = "";
            body.style.overflow = "";
          });
        }
      };

      summary.addEventListener("click", handler);
      cleanup.push(() => summary.removeEventListener("click", handler));
    });

    return () => cleanup.forEach((fn) => fn());
  });
</script>
