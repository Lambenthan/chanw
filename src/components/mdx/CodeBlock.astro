---
/**
 * 代码块折叠包裹。
 *
 * 视觉哲学："学术论文 listing"而非"UI 控件"——
 * 语言注用 italic Times serif 像脚注；折叠头部最低视觉重量；
 * 配合 vitesse-light Shiki 主题 + Times 系字体栈的代码本身。
 */
import { Icon } from "astro-icon/components";

const { class: className, style, "data-language": dataLanguage } = Astro.props;

const lang = (dataLanguage ?? className?.match(/language-(\w+)/)?.[1] ?? "")
  .toString()
  .toLowerCase();
const LANG_LABEL: Record<string, string> = {
  r: "R",
  py: "Python",
  python: "Python",
  bash: "Bash",
  sh: "Shell",
  zsh: "Shell",
  shell: "Shell",
  js: "JavaScript",
  ts: "TypeScript",
  tsx: "TypeScript",
  jsx: "JavaScript",
  sql: "SQL",
  yaml: "YAML",
  yml: "YAML",
  json: "JSON",
  html: "HTML",
  css: "CSS",
  md: "Markdown",
  mdx: "MDX",
  tex: "LaTeX",
  latex: "LaTeX",
  mermaid: "Mermaid",
};
const label = LANG_LABEL[lang] ?? (lang ? lang.toUpperCase() : "Code");
---

<details class="codeblock">
  <summary class="codeblock-summary">
    <span class="codeblock-lang">{label}</span>
    <span class="codeblock-divider"></span>
    <span class="codeblock-action">
      <span class="codeblock-action-collapsed">展开 ↓</span>
      <span class="codeblock-action-expanded">收起 ↑</span>
    </span>
  </summary>
  <div class="codeblock-body">
    <pre class={className} style={style}><slot /></pre>
  </div>
</details>

<style>
  .codeblock {
    margin: var(--space-2xs) 0 var(--space-s);
    border-top: 1px solid var(--color-tinted-cream);
    border-bottom: 1px solid var(--color-tinted-cream);
    background: transparent;
  }

  .codeblock-summary {
    display: flex;
    align-items: baseline;
    gap: var(--space-2xs);
    padding: var(--space-3xs) 0;
    cursor: pointer;
    list-style: none;
    transition: color 0.2s ease;
    color: var(--color-gray-600);
  }

  .codeblock-summary::-webkit-details-marker {
    display: none;
  }

  .codeblock-summary:hover {
    color: var(--color-sea-blue);
  }

  /* 语言标签——italic Times，像学术脚注。不是 badge，是 typography 锚 */
  .codeblock-lang {
    font-family: "TNR Numerals", "Times New Roman", serif;
    font-style: italic;
    font-size: var(--font-size-sm);
    color: var(--color-dark-sea-blue);
    letter-spacing: 0.01em;
    line-height: 1.4;
  }

  .codeblock-divider {
    flex: 1;
    height: 1px;
    background: var(--color-tinted-cream);
    margin: 0 var(--space-2xs);
    position: relative;
    top: -0.4em;
  }

  .codeblock-action {
    font-family: var(--font-sans);
    font-size: calc(var(--font-size-xs) * 0.95);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-gray-500);
    line-height: 1.4;
    flex-shrink: 0;
  }

  .codeblock-action-expanded {
    display: none;
  }
  .codeblock[open] .codeblock-action-collapsed {
    display: none;
  }
  .codeblock[open] .codeblock-action-expanded {
    display: inline;
  }

  .codeblock[open] {
    border-bottom-color: var(--color-sea-blue);
  }

  .codeblock-body {
    padding: var(--space-2xs) 0 var(--space-xs);
  }

  .codeblock-body :global(pre) {
    margin: 0;
    border: none;
    padding: var(--space-s) var(--space-m);
    box-shadow: none;
    background: var(--color-light-cream) !important;
    border-radius: 4px;
  }
</style>

<script>
  import { animate } from "motion";
  import { onPageLifecycle } from "../../utils/viewTransitionLifecycle";

  onPageLifecycle(() => {
    const blocks = document.querySelectorAll<HTMLDetailsElement>(".codeblock");
    const cleanup: (() => void)[] = [];

    blocks.forEach((details) => {
      const summary = details.querySelector<HTMLElement>(".codeblock-summary");
      const body = details.querySelector<HTMLElement>(".codeblock-body");
      if (!summary || !body) return;

      const handler = (e: Event) => {
        e.preventDefault();
        const isOpen = details.hasAttribute("open");

        if (!isOpen) {
          details.setAttribute("open", "");
          const target = body.scrollHeight;
          body.style.overflow = "hidden";
          body.style.height = "0";
          (animate as any)(
            body,
            { height: [`0px`, `${target}px`], opacity: [0, 1] },
            { duration: 0.28, easing: "ease-out" },
          ).then(() => {
            body.style.height = "auto";
            body.style.overflow = "";
          });
        } else {
          const current = body.scrollHeight;
          body.style.overflow = "hidden";
          body.style.height = `${current}px`;
          (animate as any)(
            body,
            { height: [`${current}px`, "0px"], opacity: [1, 0] },
            { duration: 0.22, easing: "ease-in" },
          ).then(() => {
            details.removeAttribute("open");
            body.style.height = "";
            body.style.opacity = "";
            body.style.overflow = "";
          });
        }
      };

      summary.addEventListener("click", handler);
      cleanup.push(() => summary.removeEventListener("click", handler));
    });

    return () => cleanup.forEach((fn) => fn());
  });
</script>
