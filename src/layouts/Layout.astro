---
import Footer from "../components/layouts/Footer.astro";
import Navbar from "../components/layouts/navbar/Navbar.astro";
import { SEO } from "astro-seo";
import { ClientRouter } from "astro:transitions";
import { Agentation } from "agentation";
import "../global.css";

export interface Props {
	title?: string;
	desc?: string;
	type?: string;
	coverImage?: string;
	canonicalURL?: string;
}

const { title, desc, type, coverImage, canonicalURL: overrideCanonicalURL } = Astro.props;

const DEFAULT_DESCRIPTION =
	"Chanw 的学术花园 —— 因果推断、人格因果学、AI 工具与开源项目策展";

const canonicalURL = overrideCanonicalURL || new URL(Astro.url.pathname, Astro.site).toString();

// Generate OG image URL based on canonical path so all versions share the same image
const canonicalPathname = new URL(canonicalURL).pathname;
const contentId = canonicalPathname.replace(/^\/?|\/?$/g, "");

// Use localhost URL in development, production URL otherwise
const baseUrl = import.meta.env.DEV ? "http://localhost:4321" : Astro.site;

// Construct OG image URL - now just using the content ID directly
const ogImageURL = type ? new URL(`/og/${contentId}.png`, baseUrl) : new URL(`/og.png`, baseUrl);

// Only add search params for non-content pages (like the homepage)
if (!type) {
	if (title) ogImageURL.searchParams.set("title", title);
	if (desc) ogImageURL.searchParams.set("description", desc);
	if (coverImage) ogImageURL.searchParams.set("coverImage", coverImage);
}

---

<!doctype html>
<html lang="zh-CN">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<meta name="color-scheme" content="light dark" />
		<link rel="apple-touch-icon" sizes="180x180" href="/images/favicon/apple-touch-icon.png" />
		<link rel="icon" type="image/png" sizes="32x32" href="/images/favicon/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/images/favicon/favicon-16x16.png" />
		<link rel="manifest" href="/manifest.json" />
		<link
			rel="alternate"
			type="application/rss+xml"
			title="Chanw's RSS Feed"
			href="/rss.xml"
		/>
		<link rel="stylesheet" href="/katex/katex.min.css" />
		<link rel="me" href="https://github.com/Lambenthan" />
		<link rel="canonical" href={canonicalURL} />
		<ClientRouter />
		<SEO
			title={title}
			description={desc || DEFAULT_DESCRIPTION}
			canonical={canonicalURL}
			openGraph={{
				basic: {
					type: "website",
					url: canonicalURL,
					title: title || "Chanw",
					image: ogImageURL.toString(),
				},
				optional: {
					locale: "zh_CN",
					description: desc || DEFAULT_DESCRIPTION,
				},
				image: {
					alt: title || "Chanw 的学术花园",
					width: 1200,
					height: 630,
				},
			}}
			twitter={{
				card: "summary_large_image",
				image: ogImageURL.toString(),
				imageAlt: title || "Chanw 的学术花园",
			}}
		/>
	</head>
	<body>
		<Navbar />
		<main>
			<slot />
		</main>
		<Footer />
		{import.meta.env.DEV && <Agentation client:only="react" />}
		<style is:global>
			/* Improve Page speed */
			/* https://css-tricks.com/almanac/properties/c/content-visibility/ */
			img {
				content-visibility: auto;
			}
		</style>
	</body>
</html>
